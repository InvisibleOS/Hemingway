# Hemingway environment. Copy to .env.local and fill in.
# The demo runs with only Supabase + Anthropic (+ Firecrawl, DataForSEO for live
# modules). Everything else is mock by design (docs/providers.md).

# ---------------------------------------------------------------------------
# Supabase (required). Project URL + keys from the Supabase dashboard.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=            # https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # anon public key (safe for the browser)
SUPABASE_SERVICE_ROLE_KEY=           # service_role key. SERVER ONLY. Bypasses RLS.

# ---------------------------------------------------------------------------
# Provider selection. Each is mock|real; default (unset) is mock.
# docs/providers.md lists which are live vs mocked in the MVP.
# ---------------------------------------------------------------------------
SCRAPER_PROVIDER=real                # Firecrawl (real in MVP)
LLM_PROVIDER=real                    # Anthropic + Voyage (real in MVP)
SEODATA_PROVIDER=real                # DataForSEO (real in MVP)
VERIFIER_PROVIDER=mock               # email verification (mocked in MVP)
SENDER_PROVIDER=mock                 # sending platform (mocked in MVP)
EXPERTFEEDS_PROVIDER=mock            # expert-request feeds (mocked in MVP)
DOMAINHEALTH_PROVIDER=mock           # domain warmup status (mocked in MVP)

# ---------------------------------------------------------------------------
# Real provider credentials (only needed when the matching *_PROVIDER=real).
# ---------------------------------------------------------------------------
# Scraper: Firecrawl (v2 endpoints)
FIRECRAWL_API_KEY=
# FIRECRAWL_API_URL=https://api.firecrawl.dev/v2   # override for self-hosted

# AI models: Anthropic for text, Voyage for embeddings (Anthropic has no embed API)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL_STRONG=claude-opus-4-8           # pitch drafting (strongest tier)
# ANTHROPIC_MODEL_LIGHT=claude-haiku-4-5           # classification (light tier)
VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-3.5                           # 1024-dim, matches the schema

# Link + AI-mention data: DataForSEO (basic auth). When SEODATA_PROVIDER=real but
# these are blank, the snapshot job falls back to mock and the report badges it
# Sandbox (Module 4). Location/language scope the AI-mention query.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
# DATAFORSEO_API_URL=https://api.dataforseo.com/v3
# DATAFORSEO_LOCATION=India                        # AI-mentions location scope
# DATAFORSEO_LANGUAGE=en                            # AI-mentions language code

# ---------------------------------------------------------------------------
# Shell providers: keys reserved for when these go live (real path is a shell
# that throws NotImplementedError until integrated). Safe to leave blank.
# ---------------------------------------------------------------------------
VERIFIER_API_KEY=                    # ZeroBounce / NeverBounce class
SENDER_API_KEY=                      # Smartlead / Instantly
EXPERTFEEDS_API_KEY=                 # Qwoted / Featured
DOMAINHEALTH_API_KEY=                # sending platform domain/warmup endpoint

# ---------------------------------------------------------------------------
# Cron. Protects the scheduled monitor-feed route (vercel.json). Optional in
# local dev (the route allows unauthenticated runs when unset).
# ---------------------------------------------------------------------------
CRON_SECRET=                         # bearer token required by /api/cron/monitor
